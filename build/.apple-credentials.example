# ─────────────────────────────────────────────────────────────────────────────
# Apple notarization credentials for `npm run dist`.
#
# 1. Copy this file to `build/.apple-credentials` (gitignored — never commit it).
# 2. Drop your downloaded App Store Connect API key (.p8) into build/ and point
#    APPLE_API_KEY at it.
# 3. Fill in the Key ID and Issuer ID shown on the API Keys page in
#    App Store Connect (https://appstoreconnect.apple.com/access/integrations/api).
#
# The `dist` script sources this file automatically so electron-builder can sign
# (Developer ID Application cert, auto-discovered from the keychain) and notarize.
# ─────────────────────────────────────────────────────────────────────────────

# Path to the downloaded .p8 API key file
export APPLE_API_KEY="build/AuthKey_XXXXXXXXXX.p8"

# The Key ID (the XXXXXXXXXX part of the filename)
export APPLE_API_KEY_ID="XXXXXXXXXX"

# The Issuer ID (a UUID shown above the keys list)
export APPLE_API_ISSUER="00000000-0000-0000-0000-000000000000"

# Your Developer ID Team ID (Apple Developer → Membership). Used for notarization.
export APPLE_TEAM_ID="XXXXXXXXXX"
