# ─────────────────────────────────────────────────────────────────────────────
# Local development only. This file is NEVER bundled into the shipped app
# (see electron-builder.yml → "!.env*") and is gitignored.
#
# All real credentials — Anthropic, Spotify, Last.fm, Genius, YouTube, and the
# Gmail SMTP password — live SERVER-SIDE in Supabase (edge-function secrets and
# Auth SMTP settings), never here and never in the client. You do not need any
# API keys in this file to run the app locally.
# ─────────────────────────────────────────────────────────────────────────────

# Optional local SMTP fallback. Production email goes through the Supabase
# `send-email` function; these are only used if that call fails during local dev.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password   # 16-char app password, not your login password

# Digest settings
DIGEST_FROM=Music Digest <your_email@gmail.com>
SEND_TIME=08:00
TIMEZONE=America/New_York

# Local server port
PORT=3000
