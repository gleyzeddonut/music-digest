# Claude API Key — get from console.anthropic.com
CLAUDE_API_KEY=your_claude_api_key_here

# Spotify Developer App — developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:3000/auth/spotify/callback

# Email delivery — Nodemailer via Yahoo SMTP
# 1. Go to Yahoo Account Security → Generate app password
# 2. Paste the 16-char app password below (no spaces)
SMTP_HOST=smtp.mail.yahoo.com
SMTP_PORT=587
SMTP_USER=your_yahoo_email@ymail.com
SMTP_PASS=your_yahoo_app_password

# Digest settings
DIGEST_TO=dan.gleyzer@ymail.com
DIGEST_FROM=Music Digest <your_yahoo_email@ymail.com>
SEND_TIME=08:00
TIMEZONE=America/New_York

# Last.fm API — register at https://www.last.fm/api/account/create
LASTFM_API_KEY=

# Genius API — register at https://genius.com/api-clients
GENIUS_API_KEY=

# Server
PORT=3000
